# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- ngrok ---
NGROK_AUTHTOKEN=
# After `docker compose up`, check http://localhost:4040 for the assigned URL,
# then paste it below and re-run the Telegram setWebhook call.
WEBHOOK_URL=https://YOUR_TUNNEL_DOMAIN.ngrok-free.app

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini ---
GEMINI_API_KEY=
# Optional: override the Gemini model
# gemini-3.1-flash-lite has 500 RPD (vs 20 RPD for 2.5-flash-lite) on the free tier
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Extraction service (internal, used by n8n HTTP Request nodes) ---
EXTRACTION_SERVICE_URL=http://extraction:8000
