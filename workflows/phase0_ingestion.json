    {
      "parameters": {
        "jsCode": "const insertResult = $input.all();\nconst prevData = $('Detect & Normalize').first().json;\nconst isDuplicate = !insertResult || insertResult.length === 0 || !insertResult[0].json.id;\nreturn [{ json: { url: prevData.url, chat_id: prevData.chat_id, is_duplicate: isDuplicate } }];"
      },
