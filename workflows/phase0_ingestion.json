      "name": "Filter: My Chat Only"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst message = body.message;\nconst text = (message.text || message.caption || '').trim();\n\n// /search command\nif (/^\\/search\\s+/i.test(text)) {\n  const query = text.replace(/^\\/search\\s+/i, '').trim();\n  return [{ json: { type: 'search', query, chat_id: message.chat.id } }];\n}\n\n// URL detection\nconst urlMatch = text.match(/(https?:\\/\\/[^\\s]+)/);\nif (!urlMatch) {\n  return [];\n}\n\nlet url = urlMatch[0];\n\n// Normalize YouTube URLs\nconst ytShort = url.match(/youtu\\.be\\/([A-Za-z0-9_-]+)/);\nif (ytShort) {\n  url = 'https://www.youtube.com/watch?v=' + ytShort[1];\n} else if (/youtube\\.com\\/watch/i.test(url)) {\n  try {\n    const u = new URL(url);\n    const v = u.searchParams.get('v');\n    if (v) url = 'https://www.youtube.com/watch?v=' + v;\n  } catch(e) {}\n}\n\nlet contentType = 'article';\nif (/youtube\\.com/i.test(url)) {\n  contentType = 'youtube';\n} else if (/spotify\\.com|podcasts\\.apple\\.com|anchor\\.fm|overcast\\.fm/i.test(url)) {\n  contentType = 'podcast';\n} else if (/twitter\\.com|x\\.com/i.test(url)) {\n  contentType = 'tweet';\n} else if (/instagram\\.com/i.test(url)) {\n  contentType = 'instagram';\n} else if (/\\.pdf(\\?.*)?$/i.test(url)) {\n  contentType = 'pdf';\n}\n\nreturn [{ json: { type: 'url', url: url, content_type: contentType, status: 'pending', chat_id: message.chat.id, telegram_message_id: message.message_id } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 220],
      "id": "9966c4a7-deb3-4faf-ac12-89236812cdb3",
      "name": "Detect & Normalize"
    },
