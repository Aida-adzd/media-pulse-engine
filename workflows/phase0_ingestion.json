    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst chatId = $('Detect & Normalize').first().json.chat_id;\n\nlet msg = '\\uD83D\\uDD0D *' + result.query + '*\\n\\n' + result.answer;\nif (result.sources && result.sources.length > 0) {\n  msg += '\\n\\n\\uD83D\\uDCDA *Sources:*';\n  for (const src of result.sources) {\n    msg += '\\n\\u2022 ' + src.title;\n  }\n}\nreturn [{ json: { chat_id: chatId, text: msg, parse_mode: 'Markdown' } }];"
      },
