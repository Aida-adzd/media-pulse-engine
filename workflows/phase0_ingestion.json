      "id": "sb-get-sources",
      "name": "Supabase: Get Sources"
    },
    {
      "parameters": {
        "jsCode": "const sources = $input.all().map(i => i.json);\nif (!sources.length) return [{ json: { text: '\ud83d\udced No completed sources yet.' } }];\nconst emoji = { youtube: '\u25b6\ufe0f', article: '\ud83d\udcc4', instagram: '\ud83d\udcf8', pdf: '\ud83d\udccb' };\nconst lines = ['\ud83d\udcda *Recent Sources:*\\n'];\nsources.forEach((s, i) => {\n  const date = (s.processed_at || '').slice(0, 10);\n  const title = (s.title || 'Untitled').slice(0, 55);\n  lines.push(`${i+1}. ${emoji[s.content_type] || '\ud83d\udd17'} *${title}*\\n   ${date}`);\n});\nreturn [{ json: { text: lines.join('\\n') } }];"
      },
