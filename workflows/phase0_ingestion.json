    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nif (!items.length) return [{ json: { text: '\ud83d\udcf0 No digest available yet. One is generated daily at 9am.' } }];\nconst d = items[0];\nconst start = (d.period_start || '').slice(0, 10);\nconst end   = (d.period_end   || '').slice(0, 10);\nconst n = (d.source_ids || []).length;\nconst content = (d.content || '').slice(0, 3500);\nconst label = d.period_type === 'weekly' ? 'Weekly' : d.period_type === 'monthly' ? 'Monthly' : 'Daily';\nreturn [{ json: { text: `\ud83d\udcf0 *${label} Digest* (${start} \u2192 ${end})\\n_Covers ${n} source(s)_\\n\\n${content}` } }];"
      },
