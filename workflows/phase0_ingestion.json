    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst message = body.message;\nconst text = (message.text || message.caption || '').trim();\nconst chat_id = message.chat.id;\n\nif (/^\\/search\\s+/i.test(text)) {\n  const query = text.replace(/^\\/search\\s+/i, '').trim();\n  return [{ json: { type: 'search', query, chat_id } }];\n}\nif (/^\\/list$/i.test(text)) {\n  return [{ json: { type: 'list', chat_id } }];\n}\nif (/^\\/tags$/i.test(text)) {\n  return [{ json: { type: 'tags', chat_id } }];\n}\nif (/^\\/digest$/i.test(text)) {\n  return [{ json: { type: 'digest', chat_id } }];\n}\n\nconst urlMatch = text.match(/(https?:\\/\\/[^\\s]+)/);\nif (!urlMatch) return [];\nlet url = urlMatch[0];\n\nconst ytShort = url.match(/youtu\\.be\\/([A-Za-z0-9_-]+)/);\nif (ytShort) {\n  url = 'https://www.youtube.com/watch?v=' + ytShort[1];\n} else if (/youtube\\.com\\/watch/i.test(url)) {\n  try { const u = new URL(url); const v = u.searchParams.get('v'); if (v) url = 'https://www.youtube.com/watch?v=' + v; } catch(e) {}\n}\n\nlet contentType = 'article';\nif (/youtube\\.com/i.test(url))                                         contentType = 'youtube';\nelse if (/spotify\\.com|podcasts\\.apple\\.com|anchor\\.fm|overcast\\.fm/i.test(url)) contentType = 'podcast';\nelse if (/twitter\\.com|x\\.com/i.test(url))                            contentType = 'tweet';\nelse if (/instagram\\.com/i.test(url))                                  contentType = 'instagram';\nelse if (/\\.pdf(\\?.*)?$/i.test(url) || /\\/pdf\\//i.test(url))          contentType = 'pdf';\n\nreturn [{ json: { type: 'url', url, content_type: contentType, status: 'pending', chat_id, telegram_message_id: message.message_id } }];"
      },
