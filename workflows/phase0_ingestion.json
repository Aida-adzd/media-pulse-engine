    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst counts = {};\nrows.forEach(r => { const n = r.tags?.name; if (n) counts[n] = (counts[n] || 0) + 1; });\nconst sorted = Object.entries(counts).sort((a,b) => b[1]-a[1]).slice(0, 20);\nif (!sorted.length) return [{ json: { text: '\ud83c\udff7\ufe0f No tags yet.' } }];\nconst lines = ['\ud83c\udff7\ufe0f *Top Tags:*\\n'];\nsorted.forEach(([tag, count], i) => lines.push(`${i+1}. ${tag} (${count})`));\nreturn [{ json: { text: lines.join('\\n') } }];"
      },
